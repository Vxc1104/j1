# Groq API (kostenlos: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Claude API (optional, für besseres Reasoning: https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Welches LLM verwenden: "groq" oder "claude"
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Groq Whisper für Sprache
STT_MODEL=whisper-large-v3-turbo

# Text-to-Speech: "macos" (gratis) oder "elevenlabs" (paid)
TTS_PROVIDER=edge
TTS_VOICE=de-DE-FlorianMultilingualNeural
TTS_RATE=+0%
TTS_PITCH=-2Hz
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Notion (https://www.notion.so/my-integrations)
NOTION_API_KEY=your_notion_key_here
NOTION_DATABASE_ID=your_database_id_here

# n8n Webhooks
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Google (OAuth credentials.json im Projektordner)
GOOGLE_CREDENTIALS_FILE=credentials.json
